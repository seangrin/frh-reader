func heightweight(h) "{\r\n\
if (h<62)\r\n\
  return 120;\r\n\
endif\r\n\
if (h<65)\r\n\
  return 130;\r\n\
endif\r\n\
if (h<67)\r\n\
  return 135;\r\n\
endif\r\n\
if (h<74)\r\n\
  return 140+(h-67)*5;\r\n\
endif\r\n\
return 180+(h-74)*10;\r\n\
}"

