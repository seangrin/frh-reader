func minmv(level) "{\r\n\
local mv;\r\n\
if (level>5) return 0; endif\r\n\
if (base_move >= 10)\r\n\
  mv = integer(base_move *\r\n\
    qindex(level, 1, .8, .6, .4, .2));\r\n\
  return max(mv, qindex(level, base_move,\r\n\
    8, 7, 6, 5));\r\n\
endif\r\n\
mv = max(1, base_move-encmv(level));\r\n\
return max(mv, qindex(level, mv, lightmin,\r\n\
  medmin, hvymin, xhvymin));\r\n\
}"

func "denc(label, level)" "format(\"%s (%d) %s\", label, minmv(level), level=enc?'*':'')"

